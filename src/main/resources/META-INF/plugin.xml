<idea-plugin>
    <id>pl.line.counter</id>
    <name>Line Counter Plugin</name>
    <vendor url="https://github.com/okultysta">okultysta</vendor>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow
                factoryClass="pl.line.counter.window.LineCounterWindowFactory"
                icon="AllIcons.Toolwindows.ToolWindowStatistics"
                id="Line Counter"
                anchor="right"/>
    </extensions>
</idea-plugin>
